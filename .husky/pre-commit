#!/usr/bin/env sh
set -eu

CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD)"

if [ "$CURRENT_BRANCH" = "master" ]; then
  echo "pre-commit: direct commits on master are forbidden. Create a branch and open a PR."
  exit 1
fi

CHANGED_FILES="$(git diff --cached --name-only)"
VERSIONS=""

echo "$CHANGED_FILES" | grep -q "^api/openapi/v1.yaml$" && VERSIONS="$VERSIONS v1" || true

if [ -n "$VERSIONS" ]; then
  npm run -s refresh:contract-hashes -- $VERSIONS
  for v in $VERSIONS; do
    git add "contracts/openapi-$v.sha256"
  done
fi

npm run -s check:contract-drift
